{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ppt-translation-cat",
  "version": "0.1.9",
  "identifier": "com.ppttranslator.desktop",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": {
      "cwd": "..",
      "script": "node ./desktop/ensure-sidecar.mjs && cd frontend && npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "node ./desktop/ensure-sidecar.mjs --force && cd frontend && npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PPT 번역캣",
        "url": "/translate",
        "width": 1100,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "capabilities": [
        "default"
      ]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBRjY1QUM5MDhFMjExQTYKUldTbUVlSUl5VnIyYWorNnppZzM4czIwZ2JObExxdExyUFNJTkcwMWNTaGtMN1lFQXhHbHorYWYK",
      "endpoints": [
        "https://github.com/Hyunsang-coder/ppt-translator/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "resources": {
      "resources/sidecar": "resources/sidecar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
