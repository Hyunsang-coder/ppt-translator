{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PPT 번역캣",
  "version": "0.1.1",
  "identifier": "com.ppttranslator.desktop",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": {
      "cwd": "..",
      "script": "./desktop/ensure-sidecar.sh && cd frontend && npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "./desktop/ensure-sidecar.sh --force && cd frontend && npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PPT 번역캣",
        "url": "/translate",
        "width": 1100,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/sidecar": "resources/sidecar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
